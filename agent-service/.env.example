# ==================== 应用配置 ====================
DEBUG=false

# ==================== 数据库配置 ====================
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/hexo_agent
POSTGRES_PASSWORD=your_db_password

# ==================== Redis 配置 ====================
REDIS_URL=redis://localhost:6379/0

# ==================== JWT 配置 ====================
SECRET_KEY=your-secret-key-change-in-production

# ==================== GitHub OAuth 配置 ====================
# 1. 去 https://github.com/settings/developers 创建 OAuth App
# 2. Homepage URL: http://localhost:8001
# 3. Authorization callback URL: http://localhost:8001/static/oauth-callback.html
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8001/static/oauth-callback.html

# ==================== AI API Keys ====================
DEEPSEEK_API_KEY=sk-your_deepseek_key
DASHSCOPE_API_KEY=sk-your_dashscope_key

# ==================== 搜索 ====================
SEARCH_ENGINE=baidu
BAIDU_SEARCH_API_KEY=your_baidu_search_key

# ==================== CORS 白名单 ====================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4001,https://your-blog-domain.com

# ==================== 博客配置 ====================
BLOG_BASE_URL=https://your-blog.github.io
BLOG_ARTICLES_DIR=/data/hexo-blog/source/_posts

# ==================== Git 同步 ====================
GIT_SYNC_ENABLED=false
# GIT_REPO_URL=https://github.com/your-backup-repo.git

# ==================== Agent ====================
REACT_MAX_ITERATIONS=8

# ==================== 前端 Widget ====================
# API_BASE 由 sync-widget.sh 注入到 Widget JS 中
API_BASE=http://localhost:8001
HEXO_THEME_PATH=/path/to/your/blog/themes/Chic

# ==================== 远程运维（agent.sh SSH 到服务器） ====================
SERVER_HOST=你的服务器IP
SERVER_USER=root
SERVER_PROJECT_PATH=/opt/hexo-agent
